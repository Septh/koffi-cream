    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run release.mts",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "release.mts",
            "args": [],
            "env": {
                "DEBUG": "1"
            },
            "console": "integratedTerminal",
            "outputCapture": "std",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ]
        }
    ]
}
