{
  "include": [
    "packages/**/*.js",
    "./release.mts"
  ],
  "compilerOptions": {    // Environment
    "module": "node20",
    "target": "ESNext",
    "lib": [ "ESNext" ],
    "types": [ "node" ],

    // Input
    "resolveJsonModule": true,

    // Output
    "rewriteRelativeImportExtensions": true,
    "noEmit": true,

    // Type checking
    "strict": true,
    "skipLibCheck": false,
    "skipDefaultLibCheck": true
  }
}
